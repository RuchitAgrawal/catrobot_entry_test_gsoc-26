# ─────────────────────────────────────────────────
#  Ecosystem Narrator — Environment Configuration
# ─────────────────────────────────────────────────

# Gemini API Key (from https://aistudio.google.com/app/apikey)
# If left blank or missing, the system automatically switches to MockClient
# and prints a bold warning in the terminal.
GEMINI_API_KEY=enter-your-api-key

# Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# FastAPI server settings
API_HOST=127.0.0.1
API_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
